RewriteRule ^ferramentas$ ferramentas.php [L]
RewriteRule ^categorias$ categorias.php [L]
RewriteRule ^planos$ planos.php [L]
RewriteRule ^guia$ start.php [L]
RewriteRule ^telegram$ telegram.php [L]
RewriteRule ^storage$ storage.php [L]
RewriteRule ^reportar$ reportar.php [L]
RewriteRule ^notificacoes$ notificacoes.php [L]
# Redireciona URL amigável "c/categorias=ias" para "categorias.php?categoria=ias"
RewriteCond %{REQUEST_URI} ^/c/categorias=(.*)$
RewriteRule ^c/categorias=(.*)$ categorias.php?categoria=$1 [L,QSA]


