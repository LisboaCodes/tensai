# Se a URL requisitada for "/app/categorias.php" com query "categoria=ALGUMA_COISA",
# redireciona (301) para "/c/categorias=ALGUMA_COISA".
RewriteCond %{THE_REQUEST} \s/app/categorias\.php\?categoria=([^\s]+)
RewriteRule ^ /c/categorias=%1 [R=301,L]

# Depois, quando alguém bater em /c/categorias=chatgpt, internamente 
# reescreve para categorias.php?categoria=$1, sem mudar a URL no navegador
RewriteCond %{REQUEST_URI} ^/c/categorias=(.*)$
RewriteRule ^c/categorias=(.*)$ categorias.php?categoria=$1 [L,QSA]


